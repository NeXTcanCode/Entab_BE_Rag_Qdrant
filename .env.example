QDRANT_URL=https://your-qdrant-cluster.example
QDRANT_API_KEY=replace-in-render-dashboard
QDRANT_COLLECTION=absb_school_code

GROQ_API_KEY=replace-in-render-dashboard
GROQ_MODEL=llama-3.1-8b-instant

GITHUB_OWNER=likhilbalakrishnan
GITHUB_REPO=Websites
GITHUB_BRANCH=main
GITHUB_TOKEN=replace-with-fine-grained-read-only-token
GITHUB_CACHE_SECONDS=300

# Multiple origins must be comma-separated.
ALLOWED_ORIGINS=https://next-doesnt-like-css.netlify.app

# Render normally has no Ollama service, so fail over to Groq quickly.
OLLAMA_CHAT_TIMEOUT=2
